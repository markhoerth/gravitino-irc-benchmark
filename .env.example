# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in your values
# .env is gitignored — never commit real credentials
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS ───────────────────────────────────────────────────────────────────────
# On EC2 with an IAM instance role, leave these blank — credentials are
# provided automatically via the instance metadata service.
# Fill in only if running locally with explicit access keys.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-2

# ── S3 ────────────────────────────────────────────────────────────────────────
# Bucket where Iceberg data and metadata will be stored.
S3_BUCKET=your-s3-bucket-name

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PORT=5432
POSTGRES_DB=iceberg_catalog
POSTGRES_USER=iceberg
POSTGRES_PASSWORD=iceberg_password

# ── Gravitino Server ─────────────────────────────────────────────────────────
GRAVITINO_API_PORT=8090
IRC_PORT=9001

# ── Trino ─────────────────────────────────────────────────────────────────────
TRINO_PORT=8080
